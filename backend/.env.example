# Server
PORT=5000

# Optional cloud database path.
# Local default: backend/amazon_price_tracker.db
# Render persistent disk example: /var/data/amazon_price_tracker.db
DB_PATH=

# Email (SMTP) — use Gmail App Password or any SMTP provider
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Price Tracker <your_email@gmail.com>

# Where competitor change alerts (price up/down, stock in/out) are sent
ALERT_EMAIL=your_email@gmail.com

# Your own Flipkart store name — your price changes never trigger alerts
MY_STORE=YourStoreName

# Main competitor, highlighted on the dashboard
PRIMARY_COMPETITOR=CompetitorName

# Login for the dashboard (required if the public tunnel is on)
APP_USER=yourname
APP_PASS=choose_a_strong_password

# Cloudflare tunnel for local-PC use only ("on"/"off").
# Keep this off in cloud hosting.
PUBLIC_TUNNEL=on
CLOUDFLARED_PATH=C:\Program Files (x86)\cloudflared\cloudflared.exe

# Telegram alerts (preferred): bot token from @BotFather + your chat id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# WhatsApp alerts via CallMeBot (optional fallback, free personal use).
# WhatsApp "I allow callmebot to send me messages" to +34 621 07 32 45, get apikey.
WHATSAPP_PHONE=+91XXXXXXXXXX
CALLMEBOT_APIKEY=

# How often to check prices (cron syntax, default: every 30 minutes)
PRICE_CHECK_CRON=*/30 * * * *

# Opening & closing business reports (cron, local time)
DIGEST_OPENING_CRON=0 9 * * *
DIGEST_CLOSING_CRON=0 21 * * *
